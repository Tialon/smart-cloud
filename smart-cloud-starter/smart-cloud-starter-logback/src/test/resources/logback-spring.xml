<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <conversionRule conversionWord="mm" converterClass="io.github.smart.cloud.starter.logback.pattern.MaskMessageConverter"/>

    <property name="log_format" value="%d{MM-dd HH:mm:ss.SSS} %level [%X{X-B3-SpanId}|%X{X-B3-ParentSpanId}|%X{X-B3-TraceId}] %thread [%logger{36} %method %line] %mm%n"/>

    <!-- 开发环境使用 打印在控制台-->
    <appender name="MEMORY" class="ch.qos.logback.core.OutputStreamAppender">
        <encoder charset="UTF-8">
            <pattern>${log_format}</pattern>
        </encoder>
        <outputStream class="java.io.ByteArrayOutputStream"/>
    </appender>

    <root>
        <level value="INFO"/>
        <appender-ref ref="MEMORY"/>
    </root>

</configuration>